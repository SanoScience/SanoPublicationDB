<!-- app/views/authors/_author_details.html.erb -->
<div class="row align-items-start">
  <div class="<%= user_signed_in? && current_user.moderator? ? 'col-md-10' : 'col-md-12' %>">
    <h2><%= author.display_name %></h2>

    <div class="d-flex gap-2 mb-3">
      <strong>Type:</strong>
      <%= author.collective? ? "Collective author" : "Person" %>
    </div>

    <% if author.collective? %>
      <div class="d-flex gap-2 mb-3">
        <strong>Collective name:</strong> <%= author.collective_name %>
      </div>
    <% else %>
      <% if author.title.present? %>
        <div class="d-flex gap-2 mb-3">
          <strong>Title:</strong> <%= author.title %>
        </div>
      <% end %>

      <% if author.first_name.present? %>
        <div class="d-flex gap-2 mb-3">
          <strong>First name:</strong> <%= author.first_name %>
        </div>
      <% end %>

      <% if author.last_name.present? %>
        <div class="d-flex gap-2 mb-3">
          <strong>Last name:</strong> <%= author.last_name %>
        </div>
      <% end %>
    <% end %>

    <div class="d-flex gap-2 mb-3">
      <strong>Publications count:</strong> <%= author.publications.distinct.count %>
    </div>
  </div>

  <% if user_signed_in? && current_user.moderator? %>
    <div class="col-md-2">
      <div class="d-grid gap-2">
        <%= link_to "Edit author",
            edit_author_path(author, back_params),
            class: "btn btn-primary",
            data: { turbo_frame: dom_id(author, :details) } %>

        <%= button_to "Delete", author_path(author, back_params),
            method: :delete,
            data: { turbo: false, confirm: "Are you sure?" },
            form: { class: "d-grid" },
            class: "btn btn-danger" %>

        <button type="button"
                class="btn btn-warning"
                data-bs-toggle="modal"
                data-bs-target="#mergeAuthorModal">
          Move authorships
        </button>
      </div>
    </div>
  <% end %>
</div>

<% if user_signed_in? && current_user.moderator? %>
  <div class="modal fade" id="mergeAuthorModal" tabindex="-1" aria-labelledby="mergeAuthorModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="mergeAuthorModalLabel">Move authorships to another author</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <%= form_with url: merge_author_path(author, back_params),
            method: :post,
            data: { turbo: false } do %>
          <div class="modal-body">
            <p class="mb-3">
              Move all authorships from <strong><%= author.display_name %></strong> to:
            </p>

            <%= label_tag :target_author_id, "Target author", class: "form-label" %>
            <%= select_tag :target_author_id,
                options_from_collection_for_select(
                  Author.where.not(id: author.id).order(:last_name, :first_name, :collective_name),
                  :id,
                  :display_name
                ),
                include_blank: "Select an author",
                class: "form-select",
                required: true %>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
              Cancel
            </button>

            <%= submit_tag "Move authorships",
                class: "btn btn-warning",
                data: {
                  confirm: "Move all authorships from #{author.display_name} to another author?"
                } %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>